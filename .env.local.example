# API Keys - Get these from the respective services

# ============================================
# REQUIRED APIs
# ============================================

# NewsAPI - https://newsapi.org
# Get key at: https://newsapi.org/register
# Free tier: 100 requests/day | Developer: 250/day | Business: Unlimited
NEWSAPI_KEY=your_newsapi_key_here

# Refresh API Token - Custom token for your refresh endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REFRESH_TOKEN=your_secure_random_token_here

# ============================================
# OPTIONAL BUT RECOMMENDED
# ============================================

# Reddit API - https://www.reddit.com/prefs/apps
# IMPORTANT: Use TRADITIONAL Reddit API, NOT Devvit
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Click "create another app"
# 3. Choose type: "script"
# 4. Name: "WorldFigures Data Fetcher"
# 5. Redirect URI: http://localhost:3000 (can be anything)
# Free tier: 60 requests per minute (unlimited daily)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ============================================
# FUTURE INTEGRATIONS (Not yet implemented)
# ============================================

# Twitter/X API - https://developer.twitter.com
# Requires approval, $100+/month for useful tiers
# TWITTER_BEARER_TOKEN=your_twitter_token

# GDELT Project - https://www.gdeltproject.org
# Free but complex to use, consider for v2
# GDELT_API_KEY=not_required_but_rate_limited
